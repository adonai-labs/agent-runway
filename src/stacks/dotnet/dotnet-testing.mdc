## Integration tests ŌĆö infrastructure layer

Use `Testcontainers` for database and external service dependencies; do not use SQLite as a substitute for SQL Server or PostgreSQL in infrastructure tests.

```csharp
public class OrderRepositoryTests : IAsyncLifetime
{
    private readonly MsSqlContainer _db = new MsSqlBuilder().Build();

    public async Task InitializeAsync() => await _db.StartAsync();
    public async Task DisposeAsync() => await _db.DisposeAsync();

    [Fact]
    public async Task SaveAsync_PersistsOrderAndRaisesEvent()
    {
        await using var context = CreateDbContext(_db.GetConnectionString());
        var repository = new OrderRepository(context);
        var order = new OrderBuilder().Build();

        await repository.SaveAsync(order, default);

        var saved = await context.Orders.FindAsync(order.Id);
        saved.Should().NotBeNull();
    }
}
```

